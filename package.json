{
  "name": "simply-toast",
  "version": "0.1.1",
  "type": "module",
  "description": "A simple toast notification library for web apps",
  "author": "Abajit abajitdey@zohomail.in",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/simply-toast.umd.cjs",
  "module": "./dist/simply-toast.js",
