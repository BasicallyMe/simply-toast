  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-css-injected-by-js": "^5.0.0"
  },
  "dependencies": {
    "@types/node": "^25.6.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
